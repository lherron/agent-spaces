{
  "name": "acp-ops-reducer",
  "version": "0.1.0",
  "private": true,
  "description": "Pure client reducer contracts and red tests for ACP operator session dashboard",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun run --cwd ../acp-ops-projection build && tsc",
    "typecheck": "bun run --cwd ../acp-ops-projection build && tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "acp-ops-projection": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}
