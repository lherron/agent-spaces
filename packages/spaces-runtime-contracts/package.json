{
  "name": "spaces-runtime-contracts",
  "version": "0.1.0",
  "description": "Cross-plane runtime DTO contracts and schema constants",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "test": "bun test",
    "prepack": "bun ../../scripts/strip-bun-exports.ts",
    "postpack": "git checkout HEAD -- package.json"
  },
  "dependencies": {
    "spaces-harness-broker-protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}
