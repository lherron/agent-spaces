{
  "name": "acp-server",
  "version": "0.1.0",
  "private": true,
  "description": "ACP HTTP surface for workflow tasks, coordination events, and runtime/session seams",
  "type": "module",
  "bin": {
    "acp-server": "./src/cli.ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "acp-core": "*",
    "acp-interface-store": "*",
    "agent-scope": "*",
    "coordination-substrate": "*",
    "hrc-core": "*",
    "hrc-sdk": "*",
    "spaces-config": "*",
    "spaces-runtime": "*",
    "wrkq-lib": "*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}
