{
  "name": "@lherron/agent-spaces",
  "version": "0.5.1",
  "description": "Command line interface for Agent Spaces v2",
  "repository": {
    "type": "git",
    "url": "https://github.com/lherron/agent-spaces"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "asp": "./bin/asp.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./core.d.ts",
      "import": "./core.js"
    },
    "./resolver": {
      "types": "./resolver.d.ts",
      "import": "./resolver.js"
    },
    "./store": {
      "types": "./store.d.ts",
      "import": "./store.js"
    },
    "./materializer": {
      "types": "./materializer.d.ts",
      "import": "./materializer.js"
    },
    "./git": {
      "types": "./git.d.ts",
      "import": "./git.js"
    },
    "./engine": {
      "types": "./engine.d.ts",
      "import": "./engine.js"
    },
    "./claude": {
      "types": "./claude.d.ts",
      "import": "./claude.js"
    },
    "./lint": {
      "types": "./lint.d.ts",
      "import": "./lint.js"
    },
    "./runtime": {
      "types": "./runtime.d.ts",
      "import": "./runtime.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "node_modules/spaces-*",
    "node_modules/agent-spaces",
    "node_modules/agent-scope",
    "core.js",
    "core.d.ts",
    "resolver.js",
    "resolver.d.ts",
    "store.js",
    "store.d.ts",
    "materializer.js",
    "materializer.d.ts",
    "git.js",
    "git.d.ts",
    "engine.js",
    "engine.d.ts",
    "claude.js",
    "claude.d.ts",
    "lint.js",
    "lint.d.ts",
    "runtime.js",
    "runtime.d.ts"
  ],
  "bundleDependencies": [
    "agent-scope",
    "agent-spaces",
    "spaces-config",
    "spaces-execution",
    "spaces-runtime",
    "spaces-harness-claude",
    "spaces-harness-codex",
    "spaces-harness-pi",
    "spaces-harness-pi-sdk"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "bun scripts/prepack.ts",
    "postpack": "bun scripts/postpack.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.72",
    "@iarna/toml": "^2.2.5",
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.3.0",
    "cli-kit": "*",
    "commander": "^14.0.0",
    "figures": "^6.1.0",
    "ora": "^9.0.0",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.7.2"
  },
  "optionalDependencies": {
    "agent-scope": "*",
    "agent-spaces": "*",
    "spaces-config": "*",
    "spaces-execution": "*",
    "spaces-runtime": "*",
    "spaces-harness-claude": "*",
    "spaces-harness-codex": "*",
    "spaces-harness-pi": "*",
    "spaces-harness-pi-sdk": "*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}
